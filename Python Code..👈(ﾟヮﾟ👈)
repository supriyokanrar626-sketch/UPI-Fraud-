ap2 = average_precision_score(y_test, y_proba_hybrid)

plt.figure(figsize=(10, 6))
plt.plot(r1, p1, label=f'Stage-1 XGB AP={ap1:.3f}', lw=2)
plt.plot(r2, p2, label=f'2-Stage Hybrid AP={ap2:.3f}', lw=2)

# Ekhane thik value bosbe
plt.scatter([final_recall], [final_precision], c='red', s=120, zorder=5,
            label=f'Final Point: P={final_precision:.2f}, R={final_recall:.2f}')

plt.xlabel('Recall', fontsize=12)
plt.ylabel('Precision', fontsize=12)
