import matplotlib.pyplot as plt
from sklearn.metrics import precision_recall_curve, average_precision_score

# 1. Final metrics gulo abar ber kor - jate latest value use hoy
tn, fp, fn, tp = confusion_matrix(y_test, final_pred).ravel()
final_recall = tp / (tp + fn)
final_precision = tp / (tp + fp)

# 2. Stage-1 er full proba
y_proba_s1 = xgb_s1.predict_proba(X_test)[:,1]

# 3. Hybrid er proba - jara safe tader 0, suspicious der NN er proba
y_proba_hybrid = np.zeros_like(y_test, dtype=float)
y_proba_hybrid[suspicious_idx_test] = y_proba_s2

# 4. PR Curve
