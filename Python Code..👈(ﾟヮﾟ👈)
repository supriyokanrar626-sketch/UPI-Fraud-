import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import TensorDataset, DataLoader, WeightedRandomSampler
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import confusion_matrix, classification_report
import numpy as np

# ========== STAGE-2 DATA PREP ==========
# Stage-1 er suspicious data ber kor
train_proba_s1 = xgb_s1.predict_proba(X_train)[:,1]
suspicious_idx_train = np.where(train_proba_s1 > STAGE1_THRESHOLD)[0]
suspicious_idx_test = np.where(y_proba_s1 > STAGE1_THRESHOLD)[0]

X_suspicious_train = X_train.iloc[suspicious_idx_train].values if hasattr(X_train, 'iloc') else X_train[suspicious_idx_train]
y_suspicious_train = y_train.iloc[suspicious_idx_train].values if hasattr(y_train, 'iloc') else y_train[suspicious_idx_train]

X_suspicious_test = X_test.iloc[suspicious_idx_test].values if hasattr(X_test, 'iloc') else X_test[suspicious_idx_test]
y_suspicious_test = y_test.iloc[suspicious_idx_test].values if hasattr(y_test, 'iloc') else y_test[suspicious_idx_test]

print("Stage-2 Train shape:", X_suspicious_train.shape)
print("Stage-2 Test shape:", X_suspicious_test.shape)
print("Stage-2 fraud %:", y_suspicious_train.mean() * 100)

# Scale
scaler = StandardScaler()
X_sus_train_sc = scaler.fit_transform(X_suspicious_train)
X_sus_test_sc = scaler.transform(X_suspicious_test)

# ========== STAGE-2 PYTORCH NN ==========
device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')

class FraudNN(nn.Module):

    def __init__(self, input_dim):

        super(FraudNN, self).__init__()

        self.net = nn.Sequential(

            nn.Linear(input_dim, 64),
            nn.BatchNorm1d(64),
            nn.ReLU(),
            nn.Dropout(0.3),

            nn.Linear(64, 32),
            nn.BatchNorm1d(32),
            nn.ReLU(),
            nn.Dropout(0.3),

            nn.Linear(32, 16),
            nn.ReLU(),

            nn.Linear(16, 1)
        )

    def forward(self, x):

        return self.net(x)

model_s2 = FraudNN(X_sus_train_sc.shape[1]).to(device)

# Imbalanced handle korar jonno WeightedRandomSampler
class_sample_count = np.array([len(np.where(y_suspicious_train == t)[0]) for t in np.unique(y_suspicious_train)])
weight = 1. / class_sample_count
samples_weight = np.array([weight[int(t)] for t in y_suspicious_train])
samples_weight = torch.from_numpy(samples_weight).double()

X_train_tensor = torch.FloatTensor(X_sus_train_sc)
y_train_tensor = torch.FloatTensor(y_suspicious_train).unsqueeze(1)
train_dataset = TensorDataset(X_train_tensor, y_train_tensor)
sampler = WeightedRandomSampler(samples_weight, len(samples_weight))
train_loader = DataLoader(train_dataset, batch_size=512, sampler=sampler)

criterion = nn.BCEWithLogitsLoss()
optimizer = optim.Adam(model_s2.parameters(), lr=0.001)

# Train
model_s2.train()
for epoch in range(60):
    for batch_X, batch_y in train_loader:
        batch_X, batch_y = batch_X.to(device), batch_y.to(device)
        optimizer.zero_grad()
        loss = criterion(model_s2(batch_X), batch_y)
        loss.backward()
        optimizer.step()
    if epoch % 15 == 0:
        print(f'Epoch {epoch}, Loss: {loss.item():.4f}')

# ========== STAGE-2 PREDICT + FINAL MERGE ==========
STAGE2_THRESHOLD = 0.48 # FP=48 target. Besi ele 0.55 kor, kom ele 0.40 kor

model_s2.eval()
X_test_tensor = torch.FloatTensor(X_sus_test_sc).to(device)
with torch.no_grad():
    y_proba_s2 = torch.sigmoid(model_s2(X_test_tensor)).cpu().numpy().ravel()

y_pred_s2 = (y_proba_s2 > STAGE2_THRESHOLD).astype(int)

# Final merge: Stage-1 e jara safe, tara 0. Suspicious gulor jonno NN er result
final_pred = np.zeros_like(y_test)
final_pred[suspicious_idx_test] = y_pred_s2

# ========== FINAL RESULT ==========
tn, fp, fn, tp = confusion_matrix(y_test, final_pred).ravel()
print("\n=== Proposed 2-Stage Hybrid ===")
print(f"TN: {tn}, FP: {fp}, FN: {fn}, TP: {tp}")
print(f"Accuracy: {(tp+tn)/(tp+tn+fp+fn):.4f}")
print(f"Precision: {tp/(tp+fp):.4f}")
print(f"Recall: {tp/(tp+fn):.4f}")
print(classification_report(y_test, final_pred, digits=4))


